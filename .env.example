# Anthropic API key — powers the AIVA conversation brain
ANTHROPIC_API_KEY=sk-ant-...

# Twilio credentials — for phone call handling
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Public URL of this deployment (used in Twilio webhooks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: lock the dashboard + data APIs behind a token.
# Visit /dashboard?token=YOURTOKEN once to sign in.
# DASHBOARD_TOKEN=change-me

# Optional: HMAC secret for signing outbound webhooks (X-AIVA-Signature).
# WEBHOOK_SIGNING_SECRET=change-me-too
